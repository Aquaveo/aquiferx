# Aquiferx environment variables
#
# Copy to .env.local for local dev, or set per-environment on Vercel
# (Production + Preview + Development — setting only Production silently
# breaks Preview deploys).

# Required: Supabase project URL + publishable key (shared with apps.geoglows
# + grace + rfs — same Supabase project, same keys).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Optional: GEOGloWS portal URL used for the Profile link target and the
# back-to-portal navbar link. Defaults to https://portal-dev.geoglows.org if
# unset. Override on a Vercel preview branch to point at a preview portal.
# VITE_PORTAL_URL=https://portal-dev.geoglows.org
